# ============================================================
# CETWorkOverTime 配置文件模板
# 复制此文件为 .env 并填入你的实际信息
# .env 文件已被 .gitignore 忽略，不会提交到 Git
# ============================================================

# ============ 基础配置 ============
# 邮件文件存放目录（相对于项目根目录）
WORK_SUMMARY_DIR=工作总结
# 输出报告目录（相对于项目根目录）
OUTPUT_DIR=output
# 邮件文件扩展名
EMAIL_FILE_EXTENSION=.eml

# ============ 编码配置 ============
# 默认编码
DEFAULT_ENCODING=gb2312
# 备选编码列表（逗号分隔）
FALLBACK_ENCODINGS=utf-8,gbk,gb18030

# ============ 输出配置 ============
# 输出格式
OUTPUT_FORMAT=markdown
# 缓存文件名
CACHE_FILENAME=.process_cache.json

# ============ 日志配置 ============
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ============ IMAP 邮箱配置 ============
# 邮箱地址
EMAIL_USERNAME=your_email@example.com
# IMAP 授权码（非登录密码）
EMAIL_PASSWORD=your_imap_auth_code
# IMAP 服务器地址（QQ企业邮箱默认 imap.exmail.qq.com）
IMAP_SERVER=imap.exmail.qq.com
# IMAP 端口
IMAP_PORT=993
# 是否使用 SSL
IMAP_USE_SSL=true
# 邮箱文件夹（&XeVPXGXlX9c- 即"工作日志"文件夹，如需收件箱可设为 INBOX）
IMAP_MAILBOX=&XeVPXGXlX9c-
# 搜索邮件主题关键词（如需精确匹配可改为：张三--工作日志）
IMAP_SEARCH_SUBJECT=--工作日志
# 搜索最近多少天的邮件
IMAP_SEARCH_DAYS=365

# ============ MySQL 数据库配置 ============
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=cetworkovertime
DB_CHARSET=utf8mb4

# ============ Web 服务配置 ============
# 定时抓取间隔（小时）
SCHEDULE_INTERVAL_HOURS=24

# ============ 清理配置 ============
# 入库后是否删除本地 .eml 文件（true/false）
CLEANUP_EML_AFTER_SYNC=true
